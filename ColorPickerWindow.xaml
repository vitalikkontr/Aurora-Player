<Window x:Class="AuroraPlayer.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цвета интерфейса"
        Width="260" Height="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True">
    <Border CornerRadius="16" Background="#1A1030"
            BorderBrush="#40A89FFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="8" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="14,12,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="ЦВЕТА ИНТЕРФЕЙСА" FontFamily="Syne" FontSize="10" FontWeight="Bold"
                           Foreground="#70FFFFFF" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="20" Height="20"
                        FontSize="10" Foreground="#50FFFFFF" Click="Close_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            </Grid>

            <!-- Выбор слота -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Border x:Name="SlotA1" CornerRadius="8" Cursor="Hand" Padding="10,5" Margin="0,0,4,0"
                        MouseLeftButtonUp="SlotClick" Tag="accent1">
                    <TextBlock Text="АКЦЕНТ" FontFamily="Syne" FontSize="8" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Border x:Name="SlotA2" CornerRadius="8" Cursor="Hand" Padding="10,5" Margin="0,0,4,0"
                        MouseLeftButtonUp="SlotClick" Tag="accent2">
                    <TextBlock Text="ВТОРИЧНЫЙ" FontFamily="Syne" FontSize="8" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Border x:Name="SlotCyan" CornerRadius="8" Cursor="Hand" Padding="10,5"
                        MouseLeftButtonUp="SlotClick" Tag="cyan">
                    <TextBlock Text="БИРЮЗА" FontFamily="Syne" FontSize="8" FontWeight="Bold" Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Превью трёх цветов -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                <Border x:Name="PreviewA1" Width="22" Height="22" CornerRadius="6" Margin="0,0,5,0"
                        Cursor="Hand" MouseLeftButtonUp="SlotClick" Tag="accent1">
                    <Border.Effect><DropShadowEffect x:Name="P1Glow" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                </Border>
                <Border x:Name="PreviewA2" Width="22" Height="22" CornerRadius="6" Margin="0,0,5,0"
                        Cursor="Hand" MouseLeftButtonUp="SlotClick" Tag="accent2">
                    <Border.Effect><DropShadowEffect x:Name="P2Glow" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                </Border>
                <Border x:Name="PreviewCyan" Width="22" Height="22" CornerRadius="6" Margin="0,0,10,0"
                        Cursor="Hand" MouseLeftButtonUp="SlotClick" Tag="cyan">
                    <Border.Effect><DropShadowEffect x:Name="P3Glow" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                </Border>
                <!-- Текущий выбранный цвет крупно -->
                <Border x:Name="CurrentColorPreview" Width="60" Height="22" CornerRadius="6" Margin="0,0,8,0"/>
                <TextBlock x:Name="HexLabel" Foreground="#70FFFFFF" FontFamily="Consolas"
                           FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Цветовой круг (Canvas, рисуется в коде) -->
            <Border Grid.Row="3" CornerRadius="110" ClipToBounds="True"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="200" Height="200" Cursor="Cross">
                <Canvas x:Name="WheelCanvas" Width="200" Height="200"
                        MouseMove="Wheel_MouseMove"
                        MouseLeftButtonDown="Wheel_MouseDown"
                        MouseLeftButtonUp="Wheel_MouseUp"
                        MouseLeave="Wheel_MouseLeave"/>
            </Border>

            <!-- Слайдер яркости -->
            <Grid Grid.Row="4" Margin="0,10,0,0">
                <Border Height="14" CornerRadius="7" x:Name="BrightnessTrack">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Black" Offset="0"/>
                            <GradientStop x:Name="BrightnessColor" Color="White" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Thumb x:Name="BrightnessThumb" Width="18" Height="18"
                       HorizontalAlignment="Left" Margin="-9,0,0,0"
                       DragDelta="Brightness_DragDelta" Cursor="Hand">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Width="16" Height="16" CornerRadius="8"
                                    Background="White" BorderBrush="#80FFFFFF" BorderThickness="2">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>

            <!-- Нижняя строка: сброс + OK -->
            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="8" BorderThickness="1"
                        BorderBrush="#35FF6060" Background="#15FF6060"
                        Cursor="Hand" MouseLeftButtonUp="Reset_Click" Padding="0,7">
                    <TextBlock Text="↺  По умолчанию" FontFamily="Syne" FontSize="9"
                               FontWeight="Bold" Foreground="#80FF8080" HorizontalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" x:Name="OkBtn" CornerRadius="8" BorderThickness="1"
                        BorderBrush="#507C6BFF" Background="#207C6BFF"
                        Cursor="Hand" MouseLeftButtonUp="Ok_Click" Padding="18,7">
                    <TextBlock Text="OK" FontFamily="Syne" FontSize="9"
                               FontWeight="Bold" Foreground="#C0FFFFFF" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
