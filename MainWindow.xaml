<Window x:Class="AuroraPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AuroraPlayer"
        mc:Ignorable="d"
        Title="Aurora Player"
        Height="680" Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToColorConverter x:Key="StrToColor"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:NotNullToVisibilityConverter x:Key="NotNullToVis"/>


        <!-- ══ ЦВЕТА ТЕМЫ (DynamicResource — меняются без перезапуска) ══ -->
        <SolidColorBrush x:Key="Accent1Brush"    Color="#7C6BFF"/>
        <SolidColorBrush x:Key="Accent2Brush"    Color="#FF6BB5"/>
        <SolidColorBrush x:Key="CyanBrush"       Color="#00E5CC"/>
        <SolidColorBrush x:Key="Accent1BrushDim" Color="#7C6BFF" Opacity="0.27"/>
        <SolidColorBrush x:Key="Accent2BrushDim" Color="#FF6BB5" Opacity="0.27"/>
        <SolidColorBrush x:Key="CyanBrushDim"    Color="#00E5CC" Opacity="0.27"/>
        <SolidColorBrush x:Key="Accent1BrushSel" Color="#7C6BFF" Opacity="0.25"/>
        <Color           x:Key="Accent1Color">#7C6BFF</Color>
        <Color           x:Key="Accent2Color">#FF6BB5</Color>
        <Color           x:Key="CyanColor"   >#00E5CC</Color>

        <!-- ══ НЕОН ПУЛЬС ══ -->
        <Storyboard x:Key="NeonPulseViolet" RepeatBehavior="Forever" Timeline.DesiredFrameRate="20">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="6" To="18" Duration="0:0:3.5" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                             From="0.5" To="0.9" Duration="0:0:3.5" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="NeonPulsePink" RepeatBehavior="Forever" Timeline.DesiredFrameRate="20">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="4" To="14" Duration="0:0:4.0" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                             From="0.4" To="0.85" Duration="0:0:4.0" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="NeonPulseCyan" RepeatBehavior="Forever" Timeline.DesiredFrameRate="20">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="4" To="12" Duration="0:0:5.0" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                             From="0.3" To="0.75" Duration="0:0:5.0" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="NeonPulseViz" RepeatBehavior="Forever" Timeline.DesiredFrameRate="20">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="5" To="14" Duration="0:0:4.0" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                             From="0.4" To="0.85" Duration="0:0:4.0" AutoReverse="True"/>
            <ColorAnimation  Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)"
                             From="#FF6BB5" To="#7C6BFF" Duration="0:0:4.0" AutoReverse="True"/>
        </Storyboard>

                <!-- Scrollbar Style -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource Accent1BrushSel}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuroraScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="4"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                            Grid.Column="0"
                                            CanContentScroll="{TemplateBinding CanContentScroll}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            Content="{TemplateBinding Content}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                               Grid.Column="1" Style="{StaticResource ThinScrollBar}"
                               Orientation="Vertical"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Base -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="50" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.93" ScaleY="0.93"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play Button (full player) -->
        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource Accent1Color}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource Accent2Color}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.06" ScaleY="1.06"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mini Play Button — pill-sized gradient circle with glow -->
        <Style x:Key="MiniPlayButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="17">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource Accent1Color}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource Accent2Color}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="5" ShadowDepth="0" Opacity="0.55"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.07" ScaleY="1.07"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.93" ScaleY="0.93"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider Style -->
        <Style x:Key="AuroraSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="14" VerticalAlignment="Center">
                            <Border Height="3" CornerRadius="2" Background="#18FFFFFF" VerticalAlignment="Center"/>
                            <Border x:Name="PART_SelectionRange" Height="3" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Background>
                                    <DynamicResource ResourceKey="SliderGradient"/>
                                </Border.Background>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="th" Width="12" Height="12" Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="4" ShadowDepth="0" Opacity="0.8"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Volume Slider -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="14" VerticalAlignment="Center">
                            <Border Height="3" CornerRadius="2" Background="#18FFFFFF" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="10" Height="10" Fill="{DynamicResource CyanBrush}">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="{DynamicResource CyanColor}" BlurRadius="3" ShadowDepth="0" Opacity="0.7"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Track List Item -->
        <Style x:Key="TrackItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="0,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent1BrushSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ROOT -->
    <Grid Margin="18,0,18,18">
        <!-- Shadow (статичная, без BlurEffect) -->
        <Rectangle RadiusX="20" RadiusY="20" Margin="0,6,0,0" Fill="#99000000" Opacity="0.7"/>

        <!-- Outer border -->
        <Border x:Name="MainBorder" CornerRadius="20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#07070F" Offset="0"/>
                    <GradientStop Color="#0D0D1F" Offset="0.5"/>
                    <GradientStop Color="#0A0F1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        <Border CornerRadius="20" ClipToBounds="True">
        <Grid x:Name="RootGrid">

            <!-- BG + декорации (скрываются в мини-режиме) -->
            <Grid x:Name="FullPlayerDecor">

            <!-- Orb 1 -->
            <Ellipse Width="300" Height="300" HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-80,-80,0,0" Opacity="0.15">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource Accent1Color}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Orb 2 -->
            <Ellipse Width="220" Height="220" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-50,-50" Opacity="0.12">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource Accent2Color}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Border glow -->
            <Border CornerRadius="20" BorderThickness="1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource Accent1Color}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Accent2Color}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
            </Grid>

                    <!-- ══════════════════ FULL PLAYER ══════════════════ -->
            <Grid x:Name="FullPlayer" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>   <!-- 0: titlebar -->
                    <RowDefinition Height="Auto"/> <!-- 1: top bar -->
                    <RowDefinition Height="Auto"/> <!-- 2: album + info -->
                    <RowDefinition Height="36"/>   <!-- 3: visualizer -->
                    <RowDefinition Height="Auto"/> <!-- 4: progress -->
                    <RowDefinition Height="Auto"/> <!-- 5: controls -->
                    <RowDefinition Height="Auto"/> <!-- 6: 3D button -->
                    <RowDefinition Height="Auto"/> <!-- 7: volume -->
                    <RowDefinition Height="*"/>    <!-- 8: playlist -->
                    <RowDefinition Height="12"/>   <!-- 9: resize handle -->
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown"
                        CornerRadius="20,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource Accent1Brush}" Opacity="0.8" Margin="0,0,5,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="3" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="AURORA PLAYER" FontFamily="Syne" FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush x:Name="LogoGradient" StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop x:Name="LogoStop0" Color="#FFFF2255" Offset="0"/>
                                        <GradientStop x:Name="LogoStop1" Color="#FFAA44FF" Offset="0.5"/>
                                        <GradientStop x:Name="LogoStop2" Color="#FF2277FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <TextBlock.Effect>
                                    <DropShadowEffect x:Name="LogoGlow" Color="#FFFF2255" BlurRadius="3" ShadowDepth="0" Opacity="0.95"/>
                                </TextBlock.Effect>
                                <!-- LogoGlow: лёгкий пульс (2 анимации вместо 5) -->
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimationUsingKeyFrames
                                                    Storyboard.TargetName="LogoGlow"
                                                    Storyboard.TargetProperty="BlurRadius"
                                                    RepeatBehavior="Forever">
                                                    <LinearDoubleKeyFrame KeyTime="0:0:0"   Value="6"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.8" Value="16"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:3.6" Value="6"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames
                                                    Storyboard.TargetName="LogoGlow"
                                                    Storyboard.TargetProperty="Opacity"
                                                    RepeatBehavior="Forever">
                                                    <LinearDoubleKeyFrame KeyTime="0:0:0"   Value="0.6"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.8" Value="1.0"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:3.6" Value="0.6"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                            <!-- Кнопка выбора цветовой темы -->
                            <Button x:Name="ColorThemeBtn" Style="{StaticResource GhostButton}" Width="28" Height="28"
                                    Margin="2,0" ToolTip="Цвета интерфейса" Click="ColorTheme_Click">
                                <Path x:Name="ThemeIconPath" Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C12.55,22 13,21.55 13,21 C13,20.74 12.9,20.51 12.74,20.33 C12.59,20.16 12.5,19.94 12.5,19.69 C12.5,19.14 12.95,18.69 13.5,18.69 L15.5,18.69 C18.54,18.69 21,16.23 21,13.19 C21,7.14 17.52,2 12,2 Z M6.5,13 C5.67,13 5,12.33 5,11.5 C5,10.67 5.67,10 6.5,10 C7.33,10 8,10.67 8,11.5 C8,12.33 7.33,13 6.5,13 Z M9.5,9 C8.67,9 8,8.33 8,7.5 C8,6.67 8.67,6 9.5,6 C10.33,6 11,6.67 11,7.5 C11,8.33 10.33,9 9.5,9 Z M14.5,9 C13.67,9 13,8.33 13,7.5 C13,6.67 13.67,6 14.5,6 C15.33,6 16,6.67 16,7.5 C16,8.33 15.33,9 14.5,9 Z M17.5,13 C16.67,13 16,12.33 16,11.5 C16,10.67 16.67,10 17.5,10 C18.33,10 19,10.67 19,11.5 C19,12.33 18.33,13 17.5,13 Z"
                                      Fill="{DynamicResource Accent1Brush}" Opacity="0.75"/>
                            </Button>
                            <!-- Кнопка выбора аудио-устройства -->
                            <Button x:Name="AudioDeviceBtn" Style="{StaticResource GhostButton}" Width="28" Height="28"
                                    Margin="2,0" ToolTip="Устройство вывода" Click="AudioDevice_Click">
                                <Path x:Name="AudioDevicePath"
                                      Data="M3,9 L3,15 L7,15 L12,20 L12,4 L7,9 Z M15,9.5 C16.1,10.7 16.8,12.3 16.8,14 C16.8,15.7 16.1,17.3 15,18.5 M17.5,7 C19.4,9 20.5,11.4 20.5,14 C20.5,16.6 19.4,19 17.5,21"
                                      Stroke="{DynamicResource Accent1Brush}" Opacity="0.65" StrokeThickness="1.3" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Width="28" Height="28"
                                    Margin="2,0" ToolTip="О программе" Click="About_Click">
                                <Path Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 0,0 12,2 Z M12,7 A1.2,1.2 0 1,1 12,9.4 A1.2,1.2 0 0,1 12,7 Z M12,11 L12,17"
                                      Stroke="{DynamicResource Accent1Brush}" Opacity="0.65" StrokeThickness="1.4"
                                      Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                            <Button x:Name="MiniBtn" Style="{StaticResource GhostButton}"
                                    Width="28" Height="28" Margin="2,0"
                                    ToolTip="Переключить мини-плеер" Click="MiniMode_Click">
                                <Path Data="M4,12 H20" Stroke="#70A89FFF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Width="28" Height="28"
                                    Margin="2,0" Click="Minimize_Click">
                                <Path Data="M6,12 H18" Stroke="#70FFFFFF" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                            <Button Style="{StaticResource GhostButton}" Width="28" Height="28"
                                    Margin="2,0" Click="Close_Click">
                                <Path Data="M7,7 L17,17 M17,7 L7,17" Stroke="{DynamicResource Accent2Brush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TOP BAR -->
                <Grid Grid.Row="1" Margin="20,0,20,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Accent1BrushSel}" CornerRadius="12"
                            BorderBrush="{DynamicResource Accent1BrushDim}" BorderThickness="1" Padding="10,4">
                        <TextBlock x:Name="FormatBadge" Text="" Foreground="#A89FFF"
                                   FontFamily="Syne" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" x:Name="EqPanel">
                        <Rectangle x:Name="Eq1" Width="3" Height="8"  RadiusX="1" RadiusY="1" Margin="1,0" Fill="{DynamicResource Accent1Brush}" VerticalAlignment="Bottom"/>
                        <Rectangle x:Name="Eq2" Width="3" Height="14" RadiusX="1" RadiusY="1" Margin="1,0" Fill="#9B7FFF" VerticalAlignment="Bottom"/>
                        <Rectangle x:Name="Eq3" Width="3" Height="10" RadiusX="1" RadiusY="1" Margin="1,0" Fill="{DynamicResource Accent2Brush}" VerticalAlignment="Bottom"/>
                        <Rectangle x:Name="Eq4" Width="3" Height="16" RadiusX="1" RadiusY="1" Margin="1,0" Fill="#FF85C5" VerticalAlignment="Bottom"/>
                        <Rectangle x:Name="Eq5" Width="3" Height="6"  RadiusX="1" RadiusY="1" Margin="1,0" Fill="{DynamicResource Accent1Brush}" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButton}" Width="32" Height="32"
                                Margin="2,0" ToolTip="Открыть папку" Click="OpenFolder_Click">
                            <Path Data="M3,7 Q3,5 5,5 H9.5 L11.5,7 H19 Q21,7 21,9 V17 Q21,19 19,19 H5 Q3,19 3,17 Z"
                                  Fill="Transparent" Stroke="#70A89FFF" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Width="32" Height="32"
                                Margin="2,0" ToolTip="Добавить файлы" Click="OpenFiles_Click">
                            <Path Data="M12,5 V19 M5,12 H19" Stroke="#70A89FFF" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                    <Border Width="18" Height="26" Background="Transparent" MouseLeftButtonDown="MiniPlayer_DragMove"/>
                </Grid>

                <!-- ALBUM ART + SONG INFO -->
                <Grid Grid.Row="2" Margin="20,0,20,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="14">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>
                        <Border CornerRadius="14" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A3E" Offset="0"/>
                                    <GradientStop Color="#2D1B4E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="AlbumImage" Stretch="UniformToFill" Opacity="0"/>
                                <TextBlock x:Name="AlbumIcon" Text="♪" FontSize="42"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#40A89FFF"/>
                            </Grid>
                        </Border>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,6,0">
                        <TextBlock x:Name="SongTitle" Text="Выберите музыку"
                                   FontFamily="Syne" FontSize="14" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#C0B8FF" Offset="0"/>
                                    <GradientStop Color="#FF8CC8" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="3" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="SongArtist" Text="Исполнитель"
                                   Foreground="#80FFFFFF" FontFamily="DM Sans" FontSize="11"
                                   Margin="0,3,0,7" TextTrimming="CharacterEllipsis">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent2Color}" BlurRadius="4" ShadowDepth="0" Opacity="0.35"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource CyanBrushDim}" CornerRadius="10" BorderBrush="{DynamicResource CyanBrushDim}"
                                    BorderThickness="1" Padding="8,3" Margin="0,0,6,0">
                                <TextBlock x:Name="TagGenre" Text="" Foreground="{DynamicResource CyanBrush}" FontSize="10" FontWeight="Normal"/>
                            </Border>
                            <Border Background="{DynamicResource Accent2BrushDim}" CornerRadius="10" BorderBrush="{DynamicResource Accent2BrushDim}"
                                    BorderThickness="1" Padding="8,3">
                                <TextBlock x:Name="TagBitrate" Text="" Foreground="{DynamicResource Accent2Brush}" FontSize="10" FontWeight="Normal"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="3" x:Name="HeartBtn" Style="{StaticResource GhostButton}"
                            Width="36" Height="36" VerticalAlignment="Top" Click="Heart_Click">
                        <TextBlock x:Name="HeartIcon" Text="♡" FontSize="18" Foreground="#50FFFFFF"/>
                    </Button>
                </Grid>

                <!-- VISUALIZER -->
                <Canvas Grid.Row="3" x:Name="VisualizerCanvas" Margin="20,0,20,0" Height="36" ClipToBounds="True"/>

                <!-- PROGRESS -->
                <Grid Grid.Row="4" Margin="20,6,20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTime" Text="0:00" Foreground="#50FFFFFF" FontSize="11" FontFamily="DM Sans"/>
                        <TextBlock x:Name="TotalTime"   Text="0:00" Foreground="#50FFFFFF" FontSize="11"
                                   FontFamily="DM Sans" HorizontalAlignment="Right" Grid.Column="1"/>
                    </Grid>
                    <Slider Grid.Row="1" x:Name="ProgressSlider" Style="{StaticResource AuroraSlider}"
                            Minimum="0" Maximum="100" Value="0" Margin="0,6,0,0"
                            IsEnabled="False"
                            ValueChanged="ProgressSlider_ValueChanged"
                            PreviewMouseLeftButtonDown="ProgressSlider_MouseDown"
                            PreviewMouseLeftButtonUp="ProgressSlider_MouseUp"
                            Thumb.DragStarted="ProgressSlider_DragStarted"
                            Thumb.DragCompleted="ProgressSlider_DragCompleted"/>
                </Grid>

                <!-- CONTROLS -->
                <Grid Grid.Row="5" Margin="16,10,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="ShuffleBtn" Style="{StaticResource GhostButton}"
                            Width="36" Height="36" HorizontalAlignment="Right" Click="Shuffle_Click">
                        <Path x:Name="ShufflePath"
                              Data="M16,3 L21,3 L21,8 M4,20 L21,3 M21,16 L21,21 L16,21 M15,15 L21,21 M4,4 L9,9"
                              Stroke="{DynamicResource CyanBrushDim}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                            Width="34" Height="34" Margin="4,0" Click="Prev_Click">
                        <Canvas Width="22" Height="22">
                            <Polygon Points="18,2 8,11 18,20" Fill="#AAFFFFFF"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="2" Width="2.5" Height="18" Fill="#AAFFFFFF" RadiusX="1" RadiusY="1"/>
                        </Canvas>
                    </Button>
                    <Button x:Name="PlayBtn" Grid.Column="2" Style="{StaticResource PlayButton}" Click="PlayPause_Click">
                        <Canvas x:Name="PlayIcon" Width="24" Height="24">
                            <Polygon Points="6,3 21,12 6,21" Fill="White"/>
                        </Canvas>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource GhostButton}"
                            Width="34" Height="34" Margin="4,0" Click="Next_Click">
                        <Canvas Width="22" Height="22">
                            <Polygon Points="4,2 14,11 4,20" Fill="#AAFFFFFF"/>
                            <Rectangle Canvas.Left="15.5" Canvas.Top="2" Width="2.5" Height="18" Fill="#AAFFFFFF" RadiusX="1" RadiusY="1"/>
                        </Canvas>
                    </Button>
                    <Button Grid.Column="4" x:Name="RepeatBtn" Style="{StaticResource GhostButton}"
                            Width="36" Height="36" HorizontalAlignment="Left" Click="Repeat_Click">
                        <Path x:Name="RepeatPath"
                              Data="M17,1 L21,5 L17,9 M3,11 L3,9 A4,4,0,0,1,7,5 L21,5 M7,23 L3,19 L7,15 M21,13 L21,15 A4,4,0,0,1,17,19 L3,19"
                              Stroke="{DynamicResource Accent1BrushDim}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                    </Button>
                </Grid>

                <!-- EQ PANEL + 3D SURROUND ROW -->
                <Grid Grid.Row="6" Margin="16,0,16,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- EQ Panel (built in code-behind) -->
                    <Border Grid.Row="0" Background="#0C1A1A3E" CornerRadius="12"
                            BorderBrush="{DynamicResource Accent1BrushSel}" BorderThickness="1" Margin="0,0,0,4"
                            MouseLeftButtonDown="EqPanel_MouseDown"
                            MouseMove="EqPanel_MouseMove"
                            MouseLeftButtonUp="EqPanel_MouseUp">
                        <StackPanel x:Name="EqContainer" Visibility="Collapsed" Margin="8,6,8,6"/>
                    </Border>

                    <!-- Audio control buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">

                        <!-- EQ Toggle -->
                        <Button Style="{StaticResource GhostButton}"
                                Width="60" Height="28" Margin="0,0,6,0"
                                Click="EqToggle_Click" ToolTip="Эквалайзер">
                            <TextBlock x:Name="EqToggleText" Text="EQ ▼"
                                       Foreground="#7C6BFF"
                                       FontFamily="Syne" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect x:Name="EqGlowEffect" Color="#7C6BFF" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Button>

                        <!-- 3D Surround -->
                        <Button x:Name="SurroundBtn" Style="{StaticResource GhostButton}"
                                Width="80" Height="28" Click="Surround_Click" ToolTip="Объёмный звук 3D">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path x:Name="SurroundPath"
                                      Data="M2,8 Q2,4 5,4 Q8,4 8,8 L8,12 Q8,16 5,16 Q2,16 2,12 Z M10,6 Q14,8 14,10 Q14,12 10,14 M16,4 Q22,7 22,10 Q22,13 16,16"
                                      Stroke="{DynamicResource CyanBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent" Width="18" Height="18" Stretch="Uniform" Opacity="0.28">
                                    <Path.Effect>
                                        <DropShadowEffect x:Name="SurroundIconGlow" Color="{DynamicResource CyanColor}" BlurRadius="0" ShadowDepth="0" Opacity="0.0"/>
                                    </Path.Effect>
                                </Path>
                                <TextBlock x:Name="Surround3DText" Text="3D" Foreground="{DynamicResource CyanBrush}" FontFamily="Syne"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect x:Name="SurroundGlow" Color="{DynamicResource CyanColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <!-- VIZ Button -->
                        <Button x:Name="VizBtn" Style="{StaticResource GhostButton}"
                                Width="72" Height="28" Margin="6,0,0,0"
                                Click="VizBtn_Click" ToolTip="Визуализатор">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="15" Height="12" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Rectangle x:Name="VizBar1" Canvas.Left="0"  Canvas.Bottom="0" Width="2.5" Height="5"  RadiusX="1" RadiusY="1" Fill="#FF6BB5"/>
                                    <Rectangle x:Name="VizBar2" Canvas.Left="4"  Canvas.Bottom="0" Width="2.5" Height="12" RadiusX="1" RadiusY="1" Fill="#FF6BB5"/>
                                    <Rectangle x:Name="VizBar3" Canvas.Left="8"  Canvas.Bottom="0" Width="2.5" Height="8"  RadiusX="1" RadiusY="1" Fill="#7C6BFF"/>
                                    <Rectangle x:Name="VizBar4" Canvas.Left="12" Canvas.Bottom="0" Width="2.5" Height="4"  RadiusX="1" RadiusY="1" Fill="#7C6BFF"/>
                                </Canvas>
                                <TextBlock x:Name="VizBtnText" Text="VIZ" FontFamily="Syne" FontSize="9" FontWeight="Bold"
                                           Foreground="#FF6BB5" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect x:Name="VizGlowEffect" Color="#FF6BB5" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <!-- MIX Button -->
                        <Button x:Name="MixerToggleBtn" Style="{StaticResource GhostButton}"
                                Width="60" Height="28" Margin="6,0,0,0"
                                Click="MixerToggle_Click" ToolTip="Канальный микшер">
                            <TextBlock x:Name="MixerToggleText" Text="MIX ▼"
                                       Foreground="#00E5CC"
                                       FontFamily="Syne" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect x:Name="MixGlowEffect" Color="#00E5CC" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Button>

                    </StackPanel>
                    <Border Width="18" Height="26" Background="Transparent" MouseLeftButtonDown="MiniPlayer_DragMove"/>

                    <!-- MIX Panel (built in code-behind) -->
                    <StackPanel x:Name="MixerContainer" Grid.Row="2"
                                Visibility="Collapsed"
                                Background="#14FFFFFF"
                                Margin="0,4,0,0">
                        <StackPanel.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </StackPanel.Resources>
                    </StackPanel>
                </Grid>

                <!-- VOLUME -->
                <Grid Grid.Row="7" Margin="20,0,20,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" x:Name="VolumeIcon"
                          Data="M11,5 L6,9 L2,9 L2,15 L6,15 L11,19 Z M15.54,8.46 A5,5,0,0,1,15.54,15.54 M19.07,4.93 A10,10,0,0,1,19.07,19.07"
                          Stroke="#40A89FFF" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                          Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"
                          Cursor="Hand" MouseLeftButtonDown="VolumeIcon_Click"/>
                    <Slider Grid.Column="1" x:Name="VolumeSlider" Style="{StaticResource VolumeSlider}"
                            Minimum="0" Maximum="100" Value="75" ValueChanged="Volume_Changed"/>
                    <TextBlock Grid.Column="2" x:Name="VolumeText" Text="75%" Foreground="#50FFFFFF"
                               FontSize="11" FontFamily="DM Sans" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- PLAYLIST -->
                <Border Grid.Row="8" Margin="0,0,0,0" BorderThickness="0,1,0,0" BorderBrush="#0DFFFFFF"
                        >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="20,10,20,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="PlaylistHeader" Text=""
                                       Foreground="#40A89FFF" FontFamily="Syne" FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                    Width="26" Height="26" Click="ClearPlaylist_Click" ToolTip="Очистить">
                                <Path Data="M18,6 L6,18 M6,6 L18,18" Stroke="{DynamicResource Accent2BrushDim}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                        </Grid>
                        <ListBox Grid.Row="1" x:Name="TrackList"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource TrackItem}"
                                 SelectionChanged="TrackList_SelectionChanged"
                                 MouseDoubleClick="TrackList_DoubleClick"
                                 PreviewMouseLeftButtonDown="TrackList_PreviewMouseLeftButtonDown"
                                 Margin="12,0,12,0">
                            <ListBox.Template>
                                <ControlTemplate TargetType="ListBox">
                                    <ScrollViewer Style="{StaticResource AuroraScrollViewer}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ListBox.Template>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Index}" Foreground="#40FFFFFF"
                                                   FontSize="12" FontFamily="DM Sans" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="34" Height="34" CornerRadius="8" Margin="0,0,10,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{Binding Color1, Converter={StaticResource StrToColor}}" Offset="0"/>
                                                    <GradientStop Color="{Binding Color2, Converter={StaticResource StrToColor}}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <!-- Заглушка — видна когда нет обложки -->
                                                <TextBlock Text="♪" FontSize="16" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#40FFFFFF"
                                                           Visibility="{Binding CoverImage, Converter={StaticResource NullToVis}}"/>
                                                <!-- Обложка из тегов -->
                                                <Image Source="{Binding CoverImage}" Stretch="UniformToFill"
                                                       Visibility="{Binding CoverImage, Converter={StaticResource NotNullToVis}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13"
                                                       FontWeight="Normal" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" Foreground="#50FFFFFF"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="3" Background="#0AFFFFFF" CornerRadius="4"
                                                Padding="5,2" Margin="6,0">
                                            <TextBlock Text="{Binding Format}" Foreground="#50FFFFFF" FontSize="9" FontWeight="Normal"/>
                                        </Border>
                                        <TextBlock Grid.Column="4" Text="{Binding Duration}" Foreground="#50FFFFFF"
                                                   FontSize="11" FontFamily="DM Sans" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Grid>
                </Border>

                <!-- RESIZE HANDLE — вынесена за пределы плейлиста чтобы всегда быть видимой -->
                <Border Grid.Row="9" Height="14" Background="#08FFFFFF" Cursor="SizeNS"
                        MouseLeftButtonDown="PlaylistResize_MouseDown"
                        MouseMove="PlaylistResize_MouseMove"
                        MouseLeftButtonUp="PlaylistResize_MouseUp">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                        <Rectangle Width="36" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#40FFFFFF" Margin="2,0"/>
                    </StackPanel>
                </Border>

            </Grid>

                    <!-- MINI PLAYER -->
            
            <Border x:Name="MiniPlayer" Visibility="Collapsed"
                    CornerRadius="26" ClipToBounds="True"
                    MouseLeftButtonDown="MiniPlayer_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E0E22" Offset="0"/>
                        <GradientStop Color="#12101E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- progress strip -->
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>

                <!--  Main row  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <!-- drag handle -->
                        <ColumnDefinition Width="10"/>
                        <!-- album art -->
                        <ColumnDefinition Width="34"/>
                        <!-- title/artist — stretches -->
                        <ColumnDefinition Width="*"/>
                        <!-- time -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- controls -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- utility buttons -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- resize grip -->
                        <ColumnDefinition Width="8"/>
                    </Grid.ColumnDefinitions>

                    <!-- Full drag zone (behind everything) -->
                    <Border Grid.Column="0" Grid.ColumnSpan="6"
                            Background="Transparent"
                            MouseLeftButtonDown="MiniPlayer_DragMove"/>

                    <!-- Drag handle visual -->
                    <Border Grid.Column="0" Width="10" VerticalAlignment="Stretch"
                            Background="Transparent" Cursor="SizeAll">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Rectangle Width="2" Height="2" Fill="#30FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                            <Rectangle Width="2" Height="2" Fill="#30FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                            <Rectangle Width="2" Height="2" Fill="#30FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                        </StackPanel>
                    </Border>

                    <!-- Album art -->
                    <Border Grid.Column="1" Width="28" Height="28" CornerRadius="7" ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A3E" Offset="0"/>
                                <GradientStop Color="#2D1B4E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="MiniAlbumImage" Stretch="UniformToFill" Opacity="0"/>
                            <TextBlock x:Name="MiniAlbumIcon" Text="♪" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#40A89FFF"/>
                        </Grid>
                    </Border>

                    <!-- Title + Artist fills all spare space -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0">
                        <TextBlock x:Name="MiniTitle" Text="Aurora Player"
                                   FontFamily="Syne" FontSize="10" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#C0B8FF" Offset="0"/>
                                    <GradientStop Color="#FF8CC8" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent1Color}" BlurRadius="3" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="MiniArtist" Text="Исполнитель"
                                   Foreground="#80FFFFFF" FontFamily="DM Sans" FontSize="10"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource Accent2Color}" BlurRadius="4" ShadowDepth="0" Opacity="0.35"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- Time display -->
                    <TextBlock Grid.Column="3" x:Name="MiniTime" Text="0:00"
                               Foreground="#40FFFFFF" FontFamily="DM Sans" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <!-- Controls: Prev | Play/Pause | Next -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Prev -->
                        <Button Style="{StaticResource GhostButton}" Width="24" Height="24"
                                Click="Prev_Click" ToolTip="Назад">
                            <Canvas Width="16" Height="16">
                                <Polygon Points="13,2 6,8 13,14" Fill="#AAFFFFFF"/>
                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="2" Height="12"
                                           Fill="#AAFFFFFF" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                        </Button>

                        <!-- Play / Pause uses MiniPlayButton style so icon is visible -->
                        <Button Style="{StaticResource MiniPlayButton}"
                                Click="PlayPause_Click" ToolTip="Воспроизвести / Пауза">
                            <!-- MiniPlayIcon is a Canvas; code-behind draws triangle or pause bars -->
                            <Canvas x:Name="MiniPlayIcon" Width="16" Height="16">
                                <!-- default: triangle play -->
                                <Polygon Points="4,2 14,8 4,14" Fill="White"/>
                            </Canvas>
                        </Button>

                        <!-- Next -->
                        <Button Style="{StaticResource GhostButton}" Width="24" Height="24"
                                Click="Next_Click" ToolTip="Вперёд">
                            <Canvas Width="16" Height="16">
                                <Polygon Points="3,2 10,8 3,14" Fill="#AAFFFFFF"/>
                                <Rectangle Canvas.Left="11" Canvas.Top="2" Width="2" Height="12"
                                           Fill="#AAFFFFFF" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                        </Button>
                    </StackPanel>
                    <Border Width="18" Height="22" Background="Transparent" MouseLeftButtonDown="MiniPlayer_DragMove"/>

                    <!-- Utility: expand | close/hide -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">

                                    <!-- Прилипнуть влево -->
                        <Button Style="{StaticResource GhostButton}" Width="22" Height="22"
                                Visibility="Collapsed" Click="SideDockLeft_Click" ToolTip="прикрепить к левому краю">
                            <Path Data="M4,4 L4,20 M8,8 L4,12 L8,16"
                                  Stroke="#50A89FFF" StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                        </Button>

                                    <!-- Развернуть -->
                        <Button Style="{StaticResource GhostButton}" Width="26" Height="22"
                                Click="MiniMode_Click" ToolTip="Развернуть">
                            <Viewbox Width="14" Height="12" Stretch="Uniform">
                                <Path Data="M2,7 L10,1 L18,7 M2,13 L10,19 L18,13"
                                      Stroke="#80A89FFF" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            </Viewbox>
                        </Button>

                                    <!-- Прилипнуть вправо -->
                        <Button Style="{StaticResource GhostButton}" Width="22" Height="22"
                                Visibility="Collapsed" Click="SideDockRight_Click" ToolTip="прикрепить к правому краю">
                            <Path Data="M18,4 L18,20 M14,8 L18,12 L14,16"
                                  Stroke="#50A89FFF" StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                        </Button>

                                    <!-- Закрыть / спрятать в бок -->
                        <Button Style="{StaticResource GhostButton}" Width="26" Height="22"
                                Click="MiniClose_Click" ToolTip="Спрятать / Закрыть">
                            <Viewbox Width="10" Height="10" Stretch="Uniform">
                                <Path Data="M1,1 L9,9 M9,1 L1,9"
                                      Stroke="{DynamicResource Accent2Brush}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <Border Width="18" Height="22" Background="Transparent" MouseLeftButtonDown="MiniPlayer_DragMove"/>

                                <!-- Схватить для ресайза (правый край) -->
                    <Border Grid.Column="6" Width="8" Background="Transparent" Cursor="SizeWE"
                            MouseLeftButtonDown="MiniResizeGrip_MouseDown"
                            MouseMove="MiniResizeGrip_MouseMove"
                            MouseLeftButtonUp="MiniResizeGrip_MouseUp">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Rectangle Width="2" Height="2" Fill="#25FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                            <Rectangle Width="2" Height="2" Fill="#25FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                            <Rectangle Width="2" Height="2" Fill="#25FFFFFF" RadiusX="1" RadiusY="1" Margin="0,1"/>
                        </StackPanel>
                    </Border>
                </Grid>

                            <!-- Полоса прогресса -->
                <Grid Grid.Row="1">
                    <Border Background="#15FFFFFF" CornerRadius="0,0,26,26"/>
                    <Border x:Name="MiniProgressBar" HorizontalAlignment="Left" CornerRadius="0,0,0,26" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource Accent1Color}" Offset="0"/>
                                <GradientStop Color="{DynamicResource Accent2Color}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                </Grid>
            </Border>

        </Grid>
        </Border>
        </Border>
    </Grid>
</Window>







